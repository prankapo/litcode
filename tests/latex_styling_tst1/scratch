% Define ncode environment: This is what a person (probably only me), is supposed to use most frequently.
\lstnewenvironment{ncode}[1][]{
    \lstset{
        caption=[],
        label={#1},
        columns=fullflexible,
        basicstyle=\ttfamily,
        keepspaces=true,
        breaklines=true,
        upquote=true,
        backgroundcolor=\color{\codebg},
        escapeinside={@<}{@>}
    }
}{}